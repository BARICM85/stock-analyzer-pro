APP_DATABASE_URL=sqlite:///./stock_analyzer.db
APP_INTEGRATION_MODE=simulated
APP_ENCRYPTION_KEY=change-this-in-production

# Zerodha OAuth
APP_ZERODHA_API_KEY=
APP_ZERODHA_API_SECRET=
APP_ZERODHA_REDIRECT_URI=http://localhost:8000/integrations/oauth/zerodha/callback
APP_ZERODHA_AUTH_URL=https://kite.zerodha.com/connect/login
APP_ZERODHA_TOKEN_URL=

# Upstox OAuth
APP_UPSTOX_CLIENT_ID=
APP_UPSTOX_CLIENT_SECRET=
APP_UPSTOX_REDIRECT_URI=http://localhost:8000/integrations/oauth/upstox/callback
APP_UPSTOX_AUTH_URL=https://api-v2.upstox.com/login/authorization/dialog
APP_UPSTOX_TOKEN_URL=https://api-v2.upstox.com/login/authorization/token

# Angel One OAuth (fill when provider app is available)
APP_ANGELONE_CLIENT_ID=
APP_ANGELONE_CLIENT_SECRET=
APP_ANGELONE_REDIRECT_URI=http://localhost:8000/integrations/oauth/angelone/callback
APP_ANGELONE_AUTH_URL=
APP_ANGELONE_TOKEN_URL=

# ICICI OAuth (fill when provider app is available)
APP_ICICI_CLIENT_ID=
APP_ICICI_CLIENT_SECRET=
APP_ICICI_REDIRECT_URI=http://localhost:8000/integrations/oauth/icici/callback
APP_ICICI_AUTH_URL=
APP_ICICI_TOKEN_URL=

# Depository connectors
APP_NSDL_API_KEY=
APP_CDSL_API_KEY=
